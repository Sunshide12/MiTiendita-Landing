---
export const prerender = false;

import { createServerClient } from '@/lib/supabase';
import OnboardingLayout from '@/layouts/OnboardingLayout.astro';
import AIProcessingStatus from '@/components/islands/AIProcessingStatus';

// 1. Verify authenticated session
const supabase = createServerClient(Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/register');

// 2. Retrieve the current user's storeId (most recent store)
const { data: store, error: storeError } = await supabase
  .from('stores')
  .select('id')
  .eq('owner_id', user.id)
  .order('created_at', { ascending: false })
  .limit(1)
  .single();

if (storeError || !store) {
  return Astro.redirect('/setup');
}

const storeId = store.id;
---

<OnboardingLayout step={5} title="Generando tu catálogo">
  <AIProcessingStatus client:load storeId={storeId} />
</OnboardingLayout>
