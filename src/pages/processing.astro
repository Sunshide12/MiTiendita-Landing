---
export const prerender = false;

import { createServerClient } from '@/lib/supabase';
import OnboardingLayout from '@/layouts/OnboardingLayout.astro';
import AIProcessingStatus from '@/components/islands/AIProcessingStatus';

// 1. Verify authenticated session
const supabase = createServerClient(Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/register');

// 2. Read storeId from URL query param (set by /upload)
const storeId = Astro.url.searchParams.get('storeId');
if (!storeId) return Astro.redirect('/setup');

// 3. Verify the store belongs to this user and get the slug for the final redirect
const { data: store } = await supabase
  .from('stores')
  .select('id, slug')
  .eq('id', storeId)
  .eq('owner_id', user.id)
  .single();

if (!store) return Astro.redirect('/setup');
---

<OnboardingLayout step={5} title="Generando tu catálogo">
  <AIProcessingStatus client:load storeId={store.id} storeSlug={store.slug} />
</OnboardingLayout>
