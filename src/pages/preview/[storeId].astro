---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import StorePreview from '@/components/islands/StorePreview';
import { createServerClient } from '@/lib/supabase';

const { storeId } = Astro.params;
if (!storeId) return Astro.redirect('/setup');

const supabase = createServerClient(Astro.cookies);

// 1. Verify authenticated session
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/register');

// 2. Fetch store (must belong to this user)
const { data: store } = await supabase
  .from('stores')
  .select('id, name, slug')
  .eq('id', storeId)
  .eq('owner_id', user.id)
  .single();

if (!store) return Astro.redirect('/setup');

// 3. Fetch products for this store
const { data: rawProducts } = await supabase
  .from('products')
  .select('id, name, description, price, category, image_url')
  .eq('store_id', store.id)
  .order('created_at', { ascending: true });

// 4. Fetch categories from the categories table (setup fallback)
const { data: storeCategories } = await supabase
  .from('categories')
  .select('id, name')
  .eq('store_id', store.id)
  .order('sort_order', { ascending: true });

// 5. Resolve image URLs
const r2PublicUrl = (import.meta.env.PUBLIC_R2_PUBLIC_URL ?? '').replace(/\/$/, '');

const products = (rawProducts ?? []).map((p) => {
  let imageUrl = '';
  if (p.image_url) {
    if (p.image_url.includes('.r2.dev')) {
      const pathname = new URL(p.image_url).pathname;
      imageUrl = `${r2PublicUrl}${pathname}`;
    } else if (p.image_url.startsWith('http')) {
      imageUrl = p.image_url;
    } else {
      imageUrl = `${r2PublicUrl}/${p.image_url}`;
    }
  }
  return {
    id: String(p.id),
    name: String(p.name ?? 'Producto'),
    category: (p.category as string | null) ?? null,
    description: p.description as string | null,
    price: p.price as number | null,
    image_url: imageUrl,
  };
});

// 6. Extract unique categories from products; fallback to store categories
const productCategories = [...new Set(
  products.map(p => p.category).filter(Boolean)
)] as string[];

const categories = productCategories.length > 0
  ? productCategories
  : (storeCategories ?? []).map(c => c.name);
---

<BaseLayout title={`${store.name} — Preview`} noindex={true}>
  <StorePreview
    client:load
    store={{ name: store.name, slug: store.slug }}
    products={products}
    categories={categories}
  />
</BaseLayout>
